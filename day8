#set data type:-
#create a set of 5 fruits and perform the following operators

fruits={"Apple","Banana","Mango","Orange","grapes"}

#add a new fruit
fruits.add("pineappale")
print(fruits)

#remove a fruit
fruits.remove("Banana")
print(fruits)

#Check if a specipic fruit in the set
fruit_to_check="Mango"
if fruit_to_check in fruits:
    print(f"{fruit_to_check} is in the set")
else:
    print(f"{fruit_to_check} is not in the set")

