#write a python function that takes a list of numbers as input,converts it to a set to remove duplicates,and returns the set
def remove_duplicates(numbers):return set(numbers)
# example
num_list=[1,2,3,4,5,1,6]
result=remove_duplicates(num_list)
print("original list:",num_list)
print("removing duplicates:",result)